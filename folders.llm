│   │   └── providers/                             # Внешние зависимости сервера
│   │       ├── postgres/
│   │       │   ├── connect.go                     # Открытие подключения
│   │       │   ├── migrate.go                     # Server DB migrations
│   │       │   ├── secret_repository.go           # Реализация repository.SecretRepository
│   │       │   ├── device_repository.go           # Реализация repository.DeviceRepository
│   │       │   ├── user_repository.go             # Реализация repository.UserRepository
│   │       │   └── migrations/
│   │       │       ├── 001_init.sql
│   │       │       └── 002_add_constraints.sql
│   │       │
│   │       ├── redis/
│   │       │   └── client.go                      # Redis adapter / cache/session storage
│   │       │
│   │       ├── monitoring/
│   │       │   └── metrics.go                     # Метрики, tracing bootstrap, etc.
│   │       │
│   │       ├── certstore/
│   │       │   └── store.go                       # Хранилище сертификатов/CRL, если внешнее
│   │       │
